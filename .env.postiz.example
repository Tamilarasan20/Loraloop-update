# ═══════════════════════════════════════════════════════════════
# Postiz Self-Hosted Environment Variables
# Copy this file to .env.postiz and fill in your API keys
# ═══════════════════════════════════════════════════════════════

# === Required Settings ===
MAIN_URL=http://localhost:4007
FRONTEND_URL=http://localhost:4007
NEXT_PUBLIC_BACKEND_URL=http://localhost:4007/api
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_STRING_1234567890abcdef
DATABASE_URL=postgresql://postiz-user:postiz-password@postiz-postgres:5432/postiz-db-local
REDIS_URL=redis://postiz-redis:6379
BACKEND_INTERNAL_URL=http://localhost:3000
TEMPORAL_ADDRESS=temporal:7233
IS_GENERAL=true
DISABLE_REGISTRATION=false
RUN_CRON=true

# === Storage Settings ===
STORAGE_PROVIDER=local
UPLOAD_DIRECTORY=/uploads
NEXT_PUBLIC_UPLOAD_DIRECTORY=/uploads

# ═══════════════════════════════════════════════════════════════
# SOCIAL MEDIA API KEYS
# Register developer apps on each platform and paste keys here
# ═══════════════════════════════════════════════════════════════

# --- X / Twitter ---
# Register at: https://developer.x.com
X_API_KEY=
X_API_SECRET=

# --- Facebook & Instagram ---
# Register at: https://developers.facebook.com
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# --- LinkedIn ---
# Register at: https://www.linkedin.com/developers
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# --- YouTube ---
# Register at: https://console.cloud.google.com (YouTube Data API v3)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# --- TikTok ---
# Register at: https://developers.tiktok.com
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=

# --- Threads ---
# Uses same Facebook app
THREADS_APP_ID=
THREADS_APP_SECRET=

# --- Pinterest ---
# Register at: https://developers.pinterest.com
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=

# --- Reddit ---
# Register at: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# --- Discord ---
# Register at: https://discord.com/developers
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN_ID=

# --- Slack ---
# Register at: https://api.slack.com/apps
SLACK_ID=
SLACK_SECRET=
SLACK_SIGNING_SECRET=

# --- Mastodon ---
MASTODON_URL=https://mastodon.social
MASTODON_CLIENT_ID=
MASTODON_CLIENT_SECRET=

# --- Dribbble ---
DRIBBBLE_CLIENT_ID=
DRIBBBLE_CLIENT_SECRET=

# --- GitHub ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ═══════════════════════════════════════════════════════════════
# OPTIONAL SERVICES
# ═══════════════════════════════════════════════════════════════

# --- OpenAI (for AI content generation) ---
OPENAI_API_KEY=

# --- Chrome Extension (for cookie-based platforms) ---
EXTENSION_ID=icpokdlcikdmemjkeoojhocmhmehpaia

# --- Misc ---
NEXT_PUBLIC_DISCORD_SUPPORT=
NEXT_PUBLIC_POLOTNO=
API_LIMIT=30
NX_ADD_PLUGINS=false

# --- Stripe (optional, for paid features) ---
FEE_AMOUNT=0.05
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_SIGNING_KEY=
STRIPE_SIGNING_KEY_CONNECT=
